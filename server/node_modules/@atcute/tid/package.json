{
  "name": "@atcute/tid",
  "version": "1.1.2",
  "description": "atproto timestamp identifier codec library",
  "keywords": [
    "atproto",
    "codec"
  ],
  "license": "0BSD",
  "repository": {
    "url": "https://github.com/mary-ext/atcute",
    "directory": "packages/utilities/tid"
  },
  "files": [
    "dist/",
    "lib/",
    "!lib/**/*.bench.ts",
    "!lib/**/*.test.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#platform/random": {
      "node": "./dist/random-node.js",
      "default": "./dist/random-web.js"
    }
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@atcute/time-ms": "^1.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.build.json",
    "test": "vitest",
    "prepublish": "rm -rf dist; pnpm run build"
  }
}