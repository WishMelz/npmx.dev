{
  "name": "@atcute/time-ms",
  "version": "1.2.3",
  "description": "high precision system time helper",
  "license": "0BSD",
  "repository": {
    "url": "https://github.com/mary-ext/atcute",
    "directory": "packages/utilities/time-ms"
  },
  "files": [
    "binding.gyp",
    "dist/",
    "lib/",
    "prebuilds/",
    "src/",
    "!lib/**/*.bench.ts",
    "!lib/**/*.test.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "deno": "./dist/index.deno.js",
      "bun": "./dist/index.bun.js",
      "node": "./dist/index.node.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@types/bun": "^1.3.9",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "prebuildify": "^6.0.1"
  },
  "scripts": {
    "install": "node-gyp-build || exit 0",
    "build:native": "prebuildify --napi --strip",
    "build": "tsgo --project tsconfig.build.json",
    "prepublish": "rm -rf dist; pnpm run build:native; pnpm run build"
  }
}